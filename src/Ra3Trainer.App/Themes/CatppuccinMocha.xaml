<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Catppuccin Mocha — 25 semantic colors -->
    <!-- Source: .trellis/spec/app/catppuccin.md -->

    <!-- Accent Colors -->
    <Color x:Key="Catppuccin.Rosewater">#F5E0DC</Color>
    <Color x:Key="Catppuccin.Flamingo">#F2CDCD</Color>
    <Color x:Key="Catppuccin.Pink">#F5C2E7</Color>
    <Color x:Key="Catppuccin.Mauve">#CBA6F7</Color>
    <Color x:Key="Catppuccin.Red">#F38BA8</Color>
    <Color x:Key="Catppuccin.Maroon">#EBA0AC</Color>
    <Color x:Key="Catppuccin.Peach">#FAB387</Color>
    <Color x:Key="Catppuccin.Yellow">#F9E2AF</Color>
    <Color x:Key="Catppuccin.Green">#A6E3A1</Color>
    <Color x:Key="Catppuccin.Teal">#94E2D5</Color>
    <Color x:Key="Catppuccin.Sky">#89DCEB</Color>
    <Color x:Key="Catppuccin.Sapphire">#74C7EC</Color>
    <Color x:Key="Catppuccin.Blue">#89B4FA</Color>
    <Color x:Key="Catppuccin.Lavender">#B4BEFE</Color>

    <!-- Text Colors -->
    <Color x:Key="Catppuccin.Text">#CDD6F4</Color>
    <Color x:Key="Catppuccin.Subtext1">#BAC2DE</Color>
    <Color x:Key="Catppuccin.Subtext0">#A6ADC8</Color>

    <!-- Overlay Colors (borders, dividers, disabled) -->
    <Color x:Key="Catppuccin.Overlay2">#9399B2</Color>
    <Color x:Key="Catppuccin.Overlay1">#7F849C</Color>
    <Color x:Key="Catppuccin.Overlay0">#6C7086</Color>

    <!-- Surface Colors (cards, elevated surfaces) -->
    <Color x:Key="Catppuccin.Surface2">#585B70</Color>
    <Color x:Key="Catppuccin.Surface1">#45475A</Color>
    <Color x:Key="Catppuccin.Surface0">#313244</Color>

    <!-- Background Colors -->
    <Color x:Key="Catppuccin.Base">#1E1E2E</Color>
    <Color x:Key="Catppuccin.Mantle">#181825</Color>
    <Color x:Key="Catppuccin.Crust">#11111B</Color>

</ResourceDictionary>
